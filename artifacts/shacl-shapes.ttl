<9d7dde0a21fe4621236f0dd02cbe7472šablona_práva,_povinnosti_nebo_právní_skutečnostiShape> a sh:NodeShape;
    sh:targetClass <https://slovník.gov.cz/generický/slovník-agendy-a112-správa-registru-rpp/pojem/šablona-práva--povinnosti-nebo-právní-skutečnosti>;
    sh:class <https://slovník.gov.cz/generický/slovník-agendy-a112-správa-registru-rpp/pojem/šablona-práva--povinnosti-nebo-právní-skutečnosti>;
    sh:nodeKind sh:IRI;
    sh:description "Seznam práv, povinností a právních skutečností (PPP), které lze na základě § 8 zákona č. 12/2020 Sb. zapsat do RPP. Šablona představuje číselník PPP, u kterých je prostřednictvím Portálu občana zápis do RPP umožněn."@cs;
    sh:name "Šablona práva, povinnosti nebo právní skutečnosti"@cs.
<984b25f0e93984a4de026ca979b99028kód_šablony_pppShape> a sh:PropertyShape;
    sh:description "Kód šablony (typu) generovaný při vytvoření typu. Kód typu je ve formátu: prefix PPP a pořadové číslo (např. PPP-12)."@cs;
    sh:name "kód šablony PPP"@cs;
    sh:path <https://slovník.gov.cz/generický/slovník-agendy-a112-správa-registru-rpp/pojem/kód-šablony-ppp>;
    sh:datatype rdfs:Literal.
<9d7dde0a21fe4621236f0dd02cbe7472šablona_práva,_povinnosti_nebo_právní_skutečnostiShape> sh:property <984b25f0e93984a4de026ca979b99028kód_šablony_pppShape>.
<29adf5c4e5fb8a99c3f65394dbe60946název_šablony_pppShape> a sh:PropertyShape;
    sh:description "Název šablony (typu) práva, povinnosti a právní skutečnosti."@cs;
    sh:name "název šablony PPP"@cs;
    sh:path <https://slovník.gov.cz/generický/slovník-agendy-a112-správa-registru-rpp/pojem/název-šablony-ppp>;
