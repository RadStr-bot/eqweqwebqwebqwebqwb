<9d7dde0a21fe4621236f0dd02cbe7472šablona_práva,_povinnosti_nebo_právní_skutečnostiShape> sh:property <80488f3037e9b813f944e727d680eb17ppp_vzniká_na_základě_službyShape>.
<1a7cee90ebb02e1ce428ad3bea18e124správnost_ppp_má_ověřovatShape> a sh:PropertyShape;
    sh:description "Právo na zápis práva, povinnosti nebo právní skutečnosti uplatní uživatel služby prostřednictvím Agentury u příslušného orgánu veřejné moci, který učinil podkladový úkon. Příslušný orgán veřejné moci osvědčí existenci práva, povinnosti nebo právní skutečnosti a potvrdí ji Agentuře, která ji zapíše do registru práv a povinností."@cs;
    sh:name "správnost PPP má ověřovat"@cs;
    sh:path <https://slovník.gov.cz/generický/slovník-agendy-a112-správa-registru-rpp/pojem/správnost-ppp-má-ověřovat>;
    sh:nodeKind sh:IRI.
